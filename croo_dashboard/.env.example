# ─────────────────────────────────────────────────────────────────────────────
# croo_dashboard/.env.example
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# The base URL of your Django backend API (do NOT include a trailing slash).
#
# Local development: leave this commented out — Vite defaults to localhost:8000
# VITE_API_URL=http://localhost:8000/api
#
# Production — uncomment and set your real backend URL:
# VITE_API_URL=https://your-production-api-domain.com/api
