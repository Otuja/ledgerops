# ─────────────────────────────────────────────────────────────────────────────
# croo_backend/.env.example
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret-key

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (add your domain in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of origins allowed to call the API from a browser
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Leave commented for local SQLite dev.
# Uncomment and set for production Postgres:
# DATABASE_URL=postgres://user:password@host:5432/ledgerops_db

# ── CROO SDK — Provider (LedgerOps) ──────────────────────────────────────────
# Get these from https://app.croo.network → your agent dashboard
CROO_SDK_KEY=croo_sk_your_ledgerops_provider_key_here
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# ── CROO SDK — Test Requester (single buyer for local testing) ────────────────
# A second agent you control — used by requester_agent.py to test your services
CROO_REQUESTER_SDK_KEY=croo_sk_your_requester_key_here

# ── Service IDs ───────────────────────────────────────────────────────────────
# After registering services on the CROO dashboard, paste their IDs here.
# These are the on-chain service identifiers (0x... addresses).
CROO_SERVICE_ID_DEFAULT=0x_your_default_service_id
CROO_SERVICE_ID_TRUST=0x_your_trust_score_service_id
CROO_SERVICE_ID_BALANCE=0x_your_balance_service_id
CROO_SERVICE_ID_VERIFY=0x_your_verify_service_id
CROO_SERVICE_ID_REPORT=0x_your_report_service_id
CROO_SERVICE_ID_EXPORT=0x_your_export_service_id

# ── Cross-Agent Diversity (for run_cross_calls.py) ────────────────────────────
# Register these agents on https://app.croo.network, then paste their SDK keys.
# Each key = a distinct wallet = proof of genuine buyer diversity.
CROO_ORCHESTRATOR_SDK_KEY=croo_sk_your_orchestrator_key_here
CROO_SECONDARY_BUYER_SDK_KEY=croo_sk_your_secondary_buyer_key_here

# Agent IDs (shown on the CROO dashboard for each agent — used in trust metadata)
LEDGEROPS_AGENT_ID=your_ledgerops_agent_id
ORCHESTRATOR_AGENT_ID=your_orchestrator_agent_id
SECONDARY_BUYER_AGENT_ID=your_secondary_buyer_agent_id
CITEABLE_AGENT_ID=

# ── Citeable Provider (optional) ──────────────────────────────────────────────
# If you've also built Citeable, add its details here.
# Calls to Citeable are automatically skipped if these are left blank.
CROO_CITEABLE_SDK_KEY=
CROO_SERVICE_ID_CITEABLE_VERIFY=
CROO_SERVICE_ID_CITEABLE_FACTCHECK=
